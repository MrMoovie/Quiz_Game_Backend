<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">


<hibernate-mapping>
    <class name="com.quiz_game.entities.StudentEntity" table="students" lazy="false">
        <id name="id" type="int" column="id">
            <generator class="native"/>
        </id>
        <property name="username" type="string" column="username"/>
        <property name="password" type="string" column="password"/>
        <property name="contactInfo" type="string" column="contact_info"/>
        <property name="fullName" type="string" column="full_name"/>
        <property name="token" type="string" column="token"/>

        <bag name="gameHistory" inverse="true" cascade="all">
            <key column="student_id"/>
            <one-to-many class="com.quiz_game.entities.TrackEntity"/>
        </bag>
    </class>

    <class name="com.quiz_game.entities.TeacherEntity" table="teachers" lazy="false">
        <id name="id" type="int" column="id">
            <generator class="native"/>
        </id>
        <property name="username" type="string" column="username"/>
        <property name="password" type="string" column="password"/>
        <property name="contactInfo" type="string" column="contact_info"/>
        <property name="fullName" type="string" column="full_name"/>
        <property name="token" type="string" column="token"/>

        <bag name="races" inverse="true" cascade="all">
            <key column="teacher_id"/>
            <one-to-many class="com.quiz_game.entities.RaceEntity"/>
        </bag>
    </class>




    <class name="com.quiz_game.entities.RaceEntity" table="races" lazy="false">
        <id name="id" type="int" column="id">
            <generator class="native"/>
        </id>
        <many-to-one name="teacher" class="com.quiz_game.entities.TeacherEntity" column="teacher_id"/>


        <property name="entryCode" type="string" column="entry_code"/>
        <property name="capacity" type="int">
            <column name="capacity" default="0"/>
        </property>
        <property name="status" type="int">
            <column name="status" default="0"/>
        </property>
        <property name="goalScore" type="int">
            <column name="goal_score" default="100"/>
        </property>
        <property name="maxCapacity" type="int">
            <column name="max_capacity" default="8"/>
        </property>

        <bag name="tracks" inverse="true" cascade="all">
            <key column="race_id"/>
            <one-to-many class="com.quiz_game.entities.TrackEntity"/>
        </bag>

    </class>

    <class name="com.quiz_game.entities.TrackEntity" table="tracks" lazy="false">
        <id name="id" type="int" column="id">
            <generator class="native"/>
        </id>
        <many-to-one name="student" class="com.quiz_game.entities.StudentEntity" column="student_id"/>
        <many-to-one name="race" class="com.quiz_game.entities.RaceEntity" column="race_id"/>
        <property name="score" type="int">
            <column name="score" default="0"/>
        </property>
        <property name="path" type="int">
            <column name="path" default="0"/>
        </property>
        <property name="pathChance" type="int">
            <column name="path_chance" default="5"/>
        </property>
        <property name="powerUp" type="int">
            <column name="power_up" default="0"/>
        </property>
        <property name="position" type="int">
            <column name="position" default="0"/>
        </property>
        <property name="currentQuestionId" type="int">
            <column name="current_question_id" default="0"/>
        </property>

    </class>


    <class name="com.quiz_game.entities.QuestionTemplateEntity" table="question_templates" lazy="false">
        <id name="id" type="int" column="id">
            <generator class="native"/>
        </id>
        <property name="template" type="string">
            <column name="template" unique="false"/>
        </property>
        <property name="maxNumber" type="int" column="max_number"/>
        <property name="level" type="string" column="level"/>
    </class>

    <class name="com.quiz_game.entities.ObjectEntity" table="objects" lazy="false">
        <id name="id" type="int" column="id">
            <generator class="native"/>
        </id>
        <property name="objectName" type="string">
            <column name="object_name"/>
        </property>
    </class>

    <class name="com.quiz_game.entities.NameEntity" table="names" lazy="false">
        <id name="id" type="int" column="id">
            <generator class="native"/>
        </id>
        <property name="name" type="string">
            <column name="name" unique="true"/>
        </property>
    </class>

    <class name="com.quiz_game.entities.ActionEntity" table="actions" lazy="false">
        <id name="id" type="int" column="id">
            <generator class="native"/>
        </id>
        <property name="actionName" type="string">
            <column name="action_name" unique="true"/>
        </property>
        <property name="actionOperation" type="string">
            <column name="action_operation"/>
        </property>
    </class>


    <class name="com.quiz_game.entities.QuestionEntity" table="questions" lazy="false">
        <id name="id" type="int" column="id">
            <generator class="native"/>
        </id>
        <many-to-one name="track" class="com.quiz_game.entities.TrackEntity" column="track_id"/>
        <property name="question" type="string">
            <column name="question"/>
        </property>
        <property name="answer" type="int"/>
        <property name="answerRight" type="boolean"/>
        <property name="score" type="int"/>

        <property name="creationDate" type="java.util.Date">
            <column name="time_stamp"/>
        </property>

    </class>





</hibernate-mapping>
